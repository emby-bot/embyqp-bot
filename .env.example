# Telegram 机器人 token
BOT_TOKEN=

# TMDB API KEY
TMDB_API_KEY=

# Bot 主人 TG ID
OWNER_CHAT_ID=

# 管理员 TG ID，多个用英文逗号分隔
ADMIN_CHAT_IDS=

# TMDB 语言
TMDB_LANGUAGE=zh-CN

# 搜索结果数量
RESULT_LIMIT=99

# 轮询超时时间
POLL_TIMEOUT=30

# 请求超时时间
REQUEST_TIMEOUT=15

# Emby 地址，支持 http://IP:端口 或 https://域名
EMBY_URL=

# Emby API KEY
EMBY_API_KEY=

# Emby 用户 ID（可留空）
EMBY_USER_ID=

# Emby Webhook 监听地址
EMBY_WEBHOOK_HOST=0.0.0.0

# Emby Webhook 监听端口
EMBY_WEBHOOK_PORT=8787

# Emby Webhook 密钥（建议 32 位随机字符串）
EMBY_WEBHOOK_SECRET=

# Telegram 频道 ID（可留空）
TG_CHANNEL_ID=

# 时区
TZ=Asia/Shanghai