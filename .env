# Telegram 机器人token
BOT_TOKEN=

# TMDB API KEY
TMDB_API_KEY=

# bot主人TG ID
OWNER_CHAT_ID=
管理员TG ID(如果有多个用英文逗号隔开，例如:ADMIN_CHAT_IDS=111111,22222)
ADMIN_CHAT_IDS=

# TMDB 语言（默认就好）
TMDB_LANGUAGE=zh-CN

# 搜索结果数量（默认就好）
RESULT_LIMIT=99

# 轮询超时时间（默认就好）
POLL_TIMEOUT=30

# 请求超时时间（默认就好）
REQUEST_TIMEOUT=15

# Emby 域名支持http（ip:端口）或https
EMBY_URL=

# Emby API KEY
EMBY_API_KEY=

# Emby 用户 ID (留空即可)
EMBY_USER_ID=

# Emby Webhook 监听地址（默认就好）
EMBY_WEBHOOK_HOST=0.0.0.0

# Emby Webhook 监听端口(无特殊情况默认即可)
EMBY_WEBHOOK_PORT=8787

# Emby Webhook 密钥（32位随机字符串）
EMBY_WEBHOOK_SECRET=

# Telegram 频道 ID
TG_CHANNEL_ID=